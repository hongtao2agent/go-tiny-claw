# Build
# If golang:1.26.1-bookworm is unavailable in your registry, override this.
GO_VERSION=1.26.1

# Runtime mode
TINY_CLAW_MODE=feishu
TINY_CLAW_PROVIDER=minimax
TINY_CLAW_ENABLE_THINKING=true
TINY_CLAW_PORT=48080

# MiniMax Anthropic-compatible API
MINIMAX_API_KEY=replace-with-your-minimax-api-key
MINIMAX_MODEL=MiniMax-M3
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic

# Feishu self-built app
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=replace-with-your-feishu-app-secret
FEISHU_VERIFY_TOKEN=replace-with-your-feishu-verify-token
FEISHU_ENCRYPT_KEY=replace-with-your-feishu-encrypt-key
